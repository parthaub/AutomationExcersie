<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    api_tests.xml
    ════════════════════════════════════════
    Runs ONLY API tests (no browser needed).
    Fastest suite — no Selenium, no browser startup time.

    HOW TO RUN:
      mvn test -Dsurefire.suiteXmlFiles=src/test/resources/suites/api_tests.xml
    ════════════════════════════════════════
-->
<suite name="API Test Suite" verbose="2" parallel="none">

    <listeners>
        <listener class-name="com.automationexercise.listeners.TestListener"/>
    </listeners>

    <test name="REST API Tests">
        <classes>
            <class name="com.automationexercise.api.ProductsApiTest"/>
        </classes>
    </test>

</suite>
